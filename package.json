{
  "name": "guidewire-blink",
  "version": "1.0.0",
  "description": "Guidewire Blink Insurance Platform - Monorepo",
  "private": true,
  "scripts": {
    "dev": "npm run dev --workspace=frontend/mobile",
    "dev:mobile": "npm run start --workspace=frontend/mobile",
    "dev:web": "npm run dev --workspace=frontend/web",
    "dev:backend": "cd backend/grid_event_service && python app/main.py",
    "dev:all": "concurrently \"npm run dev:mobile\" \"npm run dev:web\" ",
    "install:all": "npm install --workspace=frontend/mobile && npm install --workspace=frontend/web && cd backend && pip install -r requirements.txt 2>/dev/null ; echo 'Backend setup'",
    "build": "npm run build --workspace=frontend/web",
    "test": "npm test --workspace=frontend/mobile",
    "clean": "rm -rf frontend/mobile/node_modules frontend/web/node_modules frontend/mobile/.expo"
  },
  "workspaces": [
    "frontend/mobile",
    "frontend/web"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
