# ─────────────────────────────────────────────────────────────────────────────
# Blink Insurance — Environment Variables Template
# Copy this file to .env and fill in real values.
# .env is git-ignored; this file (.env.example) is committed.
# ─────────────────────────────────────────────────────────────────────────────


# ── Razorpay (Payments) ───────────────────────────────────────────────────────
# Get keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
# Set to "test" or "live"
RAZORPAY_MODE=test


# ── ML Microservice ───────────────────────────────────────────────────────────
# Base URL of the FastAPI microservice (local dev or deployed)
ML_API_URL=http://localhost:8000

# Redis broker for Celery workers
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0


# ── External Data APIs ────────────────────────────────────────────────────────
# NewsAPI (civic alerts / traffic disruptions)
# Get key from: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# OpenWeatherMap (weather & AQI data)
# Get key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_here


# ── Database (Production only) ────────────────────────────────────────────────
# PostgreSQL connection string — leave blank for SQLite in dev
DATABASE_URL=postgresql://user:password@localhost:5432/gigshield


# ── App Config ────────────────────────────────────────────────────────────────
APP_ENV=development
# development | staging | production
